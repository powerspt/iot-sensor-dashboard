# 이 파일을 복사해서  .env  로 저장하고 값을 채우세요.
#   cp .env.example .env   →   nano .env

# 세션 비밀키: 길고 랜덤한 고정값(바뀌면 모든 로그인이 풀림)
# 생성 예:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=여기에-길고-랜덤한-고정값

# Cloudflare Tunnel 토큰: Zero Trust → Networks → Tunnels 에서 터널 생성 시 발급되는 값
TUNNEL_TOKEN=여기에-Cloudflare-터널-토큰

# (선택) 관리자 계정 하드코딩: 값을 채우면 서버 시작 시 이 계정이 자동 생성됩니다.
#   - 이 계정으로 로그인하면 /admin 에서 전체 학생 수집 현황을 볼 수 있습니다.
#   - 비워 두면 관리자 계정은 만들어지지 않습니다.
ADMIN_USER=admin
ADMIN_PASSWORD=여기에-관리자-비밀번호
